# === Passive agent config (choose one) ===
# Multi-agent: JSON array of signer accounts (recommended)
# AGENT_CONFIGS='[{"accountId":"0.0.1","privateKey":"302e...","operatorPublicKey":"302a..."},{"accountId":"0.0.2","privateKey":"302e...","operatorPublicKey":"302a..."}]'

# Single agent: fallback when AGENT_CONFIGS is not set (one signer only)
# Also used as payer for: npm run create:accounts (creates 2 accounts + private inbound topics)
# Topics use payer's public key as submit key; shared listener (same keys) can post to any inbound
# HEDERA_ACCOUNT_ID=0.0.xxxxx
# HEDERA_PRIVATE_KEY=0x... or 302e...  # ECDSA hex (64 chars) or DER hex
# OPERATOR_PUBLIC_KEY=302a...

# === Contract deploy (Hardhat) ===
# Used by: npm run contracts:deploy. Network from HEDERA_NETWORK (mainnet/testnet).
# Deployer MUST be ECDSA (ED25519 accounts use account-num evm_address and fail).
# HEDERA_RPC_URL=https://testnet.hashio.io/api
# CONTRACT_OPERATOR_KEY=0x...       # deployer = only account that can call scheduleReviewTrigger

# === Shared config (all agents) ===
# HEDERA_NETWORK=testnet | mainnet (default: testnet)
HEDERA_NETWORK=testnet
AI_GATEWAY_API_KEY=sk-...
# OPENAI_API_KEY=sk-...  # alternative to AI_GATEWAY_API_KEY

# Project topics (required for check flow)
PROJECT_OPERATOR_ACCOUNT_ID=0.0.xxxxx
PROJECT_REJECTION_TOPIC=0.0.xxxxx
# Operator inbound topic - all agents subscribe; keyring operator posts schedule IDs here
OPERATOR_INBOUND_TOPIC_ID=0.0.xxxxx

# ScheduleReviewTrigger: deployer (CONTRACT_OPERATOR_KEY) is the only allowed caller

# Optional
# PROJECT_REGISTRY_TOPIC=0.0.xxxxx
# PROJECT_VALIDATOR_TOPIC=0.0.xxxxx
# PROJECT_AUDIT_TOPIC=0.0.xxxxx
# PROJECT_CONTRACTS_TOPIC=0.0.xxxxx
# LYNX_REGISTRATION_TX=0.0.xxxxx@1234567890.123456789
